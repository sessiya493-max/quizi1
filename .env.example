# ================================================================
#  RAILWAY ENVIRONMENT VARIABLES — shu qiymatlarni to'ldiring
#  Railway Dashboard → Your Project → Variables bo'limiga kiriting
# ================================================================

# @BotFather dan olingan bot token
BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff

# my.telegram.org dan
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# console.groq.com dan
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sizning Telegram ID ingiz (@userinfobot ga yozing)
ADMIN_IDS=123456789

# User harakatlari log yuboriladigan guruh ID (0 = o'chirilgan)
# Guruh ID ni olish: guruhga @userinfobot qo'shing yoki forward qiling
LOG_GROUP_ID=-1001234567890

# @humocardbot xabar keladigan raqam
NOTIFY_PHONE=+998934897111

# Quiz yaratish uchun telefon raqamlar (vergul bilan)
PHONE_NUMBERS=+998901234567,+998901234568

# Humo karta raqamlar (vergul bilan, bo'shliq bilan yozish mumkin)
HUMO_CARDS=9860 1234 5678 9001,9860 1234 5678 9002,9860 1234 5678 9003

# Reklama (0 = o'chirish)
AD_EVERY=6
AD_TEXT=📢 @quiz_import_bot — AI yordamida @QuizBot testi yarating!

# Groq modeli (o'zgartirmasangiz ham bo'ladi)
GROQ_MODEL=llama-3.3-70b-versatile

# ================================================================
#  CLICK TO'LOV TIZIMI  (https://merchant.click.uz dan olinadi)
# ================================================================

# Ilovangizning to'liq URL manzili (Railway domen)
APP_URL=https://quizimport-production.up.railway.app

# Click Merchant kabineti → Xizmatlar → O'z xizmatingiz
CLICK_SERVICE_ID=12345

# Click Merchant kabineti → Profil → Merchant ID
CLICK_MERCHANT_ID=12345

# Click Merchant kabineti → Xizmatlar → Secret key
CLICK_SECRET_KEY=your_click_secret_key_here

# Click Merchant kabineti → Profil → Merchant User ID
CLICK_MERCHANT_USER_ID=12345
